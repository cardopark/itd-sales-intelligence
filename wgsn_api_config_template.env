# WGSN Sales Intelligence API configuration template
# 실제 API 키는 GitHub에 올리지 말고 로컬/서버의 보안 환경변수로만 관리하세요.

API_SOURCE_PRIORITY=NAVER,GOOGLE,OPENDART

# NAVER Search API
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# Google Programmable Search JSON API
GOOGLE_SEARCH_API_KEY=
GOOGLE_SEARCH_ENGINE_ID=

# OpenDART API
OPENDART_API_KEY=

# Optional email delivery
EMAIL_PROVIDER=
EMAIL_FROM=
SMTP_HOST=
SMTP_PORT=
SMTP_USERNAME=
SMTP_PASSWORD=
